<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:animateLayoutChanges="true"
    android:background="@drawable/bg"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/registerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/seri_logo"
                android:layout_width="@dimen/logo_width"
                android:layout_height="@dimen/logo_height"
                android:layout_gravity="center"
                android:contentDescription="@string/srei_logo"

                android:src="@drawable/srei_logo_trans_white" />
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/mobileVerificationView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/emp_login"
            android:layout_width="@dimen/login_details_container_width"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/margin_register"
            android:background="@color/white"
            android:focusableInTouchMode="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_user_details"
                android:background="@color/white"
                android:orientation="horizontal">

                <ImageView
                    style="@style/SreiImageLogin"
                    android:layout_width="@dimen/icon_width"
                    android:layout_height="@dimen/icon_height"

                    android:contentDescription="TODO"
                    android:src="@drawable/user_icon" />

                <jaanpehchan.rural.srei.CustomFontEditText
                    android:id="@+id/sm_code"
                    app:fontName="Avenir_Book_01"
                    style="@style/SreiEditLogin"
                    android:inputType="number"
                    android:layout_marginRight="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/sm_code" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/separator_height"
                android:background="@color/separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_user_details"
                android:background="@color/white"
                android:orientation="horizontal">

                <ImageView
                    style="@style/SreiImageLogin"
                    android:layout_width="@dimen/icon_width"
                    android:layout_height="@dimen/icon_height"
                    android:contentDescription="TODO"
                    android:src="@drawable/phone_icon" />

                <jaanpehchan.rural.srei.CustomFontEditText
                    android:id="@+id/mobile_no"
                    app:fontName="Avenir_Book_01"
                    style="@style/SreiEditLogin"
                    android:layout_marginRight="12dp"
                    android:layout_marginEnd="12dp"
                    android:inputType="phone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/mobile_number" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:elevation="8dp">

                <Button
                    android:id="@+id/button_register"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    style="@style/SreiButtonLogin"
                    android:text="@string/register"
                    android:elevation="8dp"/>

                <ImageView
                    android:layout_width="@dimen/image_next"
                    android:layout_height="@dimen/image_next"
                    android:layout_alignEnd="@id/button_register"
                    android:layout_alignRight="@id/button_register"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/padding_register"
                    android:layout_marginRight="@dimen/padding_register"
                    android:elevation="8dp"
                    android:src="@drawable/right_arrow_circle_icon" />
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
