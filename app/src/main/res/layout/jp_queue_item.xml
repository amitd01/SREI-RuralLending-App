<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="53dp"
    android:gravity="center"
    android:background="@color/white"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/active"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="center"
            android:contentDescription="TODO"
            android:src="@drawable/current_active_menu_indicator" />


        <jaanpehchan.rural.srei.CustomFontTextView
            android:id="@+id/lead_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity=""
            android:hint="LEAD ID"
            android:padding="10dp"
            android:textColor="#000000"
            android:textSize="@dimen/textsize_item"
            app:fontName="Avenir_Book_01" />

    </LinearLayout>


    <View
        android:layout_width="1dp"
        android:layout_height="38dp"
        android:background="@color/separator" />

    <android.support.constraint.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/status_image"
            android:layout_width="93dp"
            android:layout_height="31dp"
            android:width="0dp"
            android:contentDescription="TODO"
            android:gravity="center"
            android:src="@drawable/jp_queue_status_accepted"
            android:textColor="#000000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <jaanpehchan.rural.srei.CustomFontTextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:hint="ACCEPTED"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:fontName="Avenir_Book_01" />
    </android.support.constraint.ConstraintLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="38dp"
        android:background="@color/separator" />


    <jaanpehchan.rural.srei.CustomFontTextView
        android:id="@+id/remark"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:width="0dp"
        android:gravity="center"
        android:hint="Completed"
        android:textColor="#000000"
        android:textSize="@dimen/textsize_item"
        app:fontName="Avenir_Book_01" />
</LinearLayout>