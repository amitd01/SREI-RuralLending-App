<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/srei_logo"
        android:layout_width="250dp"
        android:layout_height="126dp"
        android:layout_marginTop="31dp"
        android:background="@drawable/srei_logo_trans_white"
        android:contentDescription="TODO"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/big_rectangle"
        android:layout_width="260dp"
        android:layout_height="22dp"
        android:background="@drawable/big_rectangle"
        app:layout_constraintBottom_toTopOf="@+id/container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/small_rectangle"
        android:layout_width="318dp"
        android:layout_height="11dp"
        android:background="@drawable/small_rectangle"
        app:layout_constraintBottom_toBottomOf="@+id/big_rectangle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="190dp"
        android:background="@color/white"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/tick_mark"
            android:layout_width="171dp"
            android:layout_height="171dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="59dp"
            android:contentDescription="TODO"
            android:src="@drawable/tickmark" />

        <jaanpehchan.rural.srei.CustomFontTextView
            android:id="@+id/text_congratulation"
            style="@style/AppTheme.TextStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15.3dp"
            android:gravity="center"
            android:text="@string/welcome_onboard_text"
            android:textSize="30sp"
            app:fontName="Avenir_Book_01" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>